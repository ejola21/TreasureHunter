    "ar_tip1" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The distance of closest item is displayed. In case of the item that has Stealth attribute, its distance will not be shown"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "현재 가장 가까운 거리에 있는 아이템의 거리가 표시 됩니다. 스텔스 속성 아이템의 경우는 안보입니다."
          }
        }
      }
    },
    "ar_tip2" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "It is the visibility range in which the item can be seen in AR screen. Only the item that is in the visibility range can be seen and won"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "증강현실 화면에서 아이템을 볼수 있는 유효 반경입니다. 아이템의 거리가 유효반경 이내에 있어야 아이템을 볼수 있고 획득이 가능합니다."
          }
        }
      }
    },
    "ar_tip3" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fit the hour hand(item direction) into the fan shape(phone direction). Item will be shown in AR screen once item comes into the visibility range. Shake to win!!!"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "시침(아이템방향)과 부채꼴(폰방향)을 일치시키고, 아이템의 거리가 유효반경안에 들어오면 증강현실 화면에 아이템이 보입니다. 획득은 Shake!!!"
          }
        }
      }
    },
